<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title | default: 'Francesca Loren' }}</title>
  {{ content_for_header }}

  <style>
    * {box-sizing: border-box;}

    body, html {
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    /* ==================== NAVBAR ==================== */
    .navbar {
      background-color: #fff;
      border: 2px solid #000;
      margin-top: 10px;                    /* Top whitespace */
      margin-left: 11px;                   /* Left whitespace */
      margin-right: 5px;                  /* Right whitespace */

      background-color: #fff;
      padding: 16px 20px; /* padding: 25px 30px;*/
      position: relative;
      z-index: 1001;
      font-family: Arial, sans-serif;
     width: calc(100% - 23px);
    }

    .navbar-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      margin: 0 auto;
    }

    .logo-link {
      color: #000;
      font-size: 36px;
      font-weight: bold;
      text-decoration: none;
      font-style: italic;
      white-space: nowrap;
    }

    /* ==================== IMAGES ==================== */
    .image-container-1 {
      width: 100%;
      position: relative;
      padding: 0 15px;              /* Same side padding as navbar for perfect alignment */
      margin-top: 10px;
    }

    .image-1 {
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
      border: 2px solid #000;
    }

/* ==================== DESKTOP ONLY - First Main Image ==================== */
@media screen and (min-width: 769px) {
  .image-container-1 {
    margin-top: 10px;
    margin-left: 0;
    margin-right: 0;
 
    width: 100%;
    height: 4400px;           /* ← Main height you should start with */
    box-sizing: border-box;
    display: grid;
    position: relative;
    z-index: 1;
    overflow: visible;
    
    /* Optional improvements for desktop */
    /* max-width: 1400px; */   /* uncomment + add margin: 0 auto; if you want it centered/not full bleed */
    /* margin: 10px auto 0; */
  }

  .image-1 {
    width: 100%;
    height: 36.7%;           /* Changed from 36.7% → 100% so it fills the container properly */
    object-fit: cover;
    display: block;
    z-index: 2;
    border: 2px solid black;
  }
}


/*new for added space and length for scrolling*/
/* Add this at the bottom of your <style> section */
.content-section {
  margin: 20px 15px;
  padding: 60px 40px;
  border: 2px solid #000;
  background-color: #fff;
  min-height: 800px;   /* adjust as needed */
}




   
/* ==================== FOOTER / COPYRIGHT ==================== */
     /* Footer */
    footer {
      width: 100%;
      position: static;
    }

  .copyright_text {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 25px 0;
      font-size: 20px;           /* Desktop font size */
    }


/* ==================== RESPONSIVE ==================== */
@media screen and (max-width:768px) {
  .navbar {
    margin: 12px 11px 0px 11px;
    padding: 8px 15px;        /* Reduced vertical padding → makes navbar shorter */
    width: calc(100% - 22px);
  }
  
  .logo-link {
    font-size: 18px;           /* Slightly smaller text to help with height */
  }
  
  .image-container-1 {
    padding: 0 11px;
    margin-top: 5px;
    margin-bottom: 0px;}


.copyright_text { 
      
        font-size: 16px;         /* Smaller font size on mobile */
      }



  </style>
</head>
<body>

  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="logo-link">HARLE</a>
    </div>
  </nav>



  <main>
    {{ content_for_layout }}
  </main>



{% include 'sticky-note' %}

  {% section 'footer' %}
  {{ content_for_footer }}

</body>
</html>
